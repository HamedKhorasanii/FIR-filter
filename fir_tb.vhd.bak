library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;
use STD.TEXTIO.ALL;  -- ???? ????? ?? ????

entity fir_tb is
end fir_tb;

architecture Behavioral of fir_tb is
    -- ?????????? ????? ?? ?????
    signal clk : std_logic := '0';
    signal rst : std_logic := '1';
    signal x_in : signed(7 downto 0) := (others => '0');
    signal y_out : signed(9 downto 0);
    
    -- ????? ???? ?????
    file output_file : text open write_mode is "output.txt";
    
begin
    -- ????? ???? (?? 10ns ????? ????? ????? = ???? 20ns)
    clk <= not clk after 10 ns;
    
    -- ????? ?????
    UUT: entity work.fir_filter
        port map (
            clk => clk,
            rst => rst,
            x_in => x_in,
            y_out => y_out
        );
    
    -- ?????? ????: ????? ????? ? ????? ?????
    process
        variable line_out : line;  -- ???? ????? ?? ????
        variable clean_val : real;
        variable noise_val : real;
        variable noisy_int : integer;
    begin
        -- ???? ?????
        rst <= '1';
        wait for 40 ns;
        rst <= '0';
        wait for 20 ns;
        
        -- ????? 200 ?????
        for i in 0 to 199 loop
            -- ?????? ???? (?????? ?? ????? 50)
            clean_val := 50.0 * sin(2.0 * 3.14159 * 5.0 * real(i) / 1000.0);
            
            -- ???? ?????? (????? -50 ?? +50)
            noise_val := real((i * 1103515245 + 12345) mod 100000) / 1000.0 - 50.0;
            
            -- ??? ?????? ? ????
            noisy_int := integer(clean_val + noise_val);
            
            -- ????? ???? ?? ?????? 8 ??? signed (-128 ?? 127)
            if noisy_int > 127 then 
                noisy_int := 127; 
            elsif noisy_int < -128 then 
                noisy_int := -128; 
            end if;
            
            -- ????? ?????
            x_in <= to_signed(noisy_int, 8);
            
            -- ??? ?? ????
            wait for 20 ns;
            
            -- ????? ?? ????: ???? ???=?????? ???? ???=?????
            write(line_out, to_integer(x_in));
            write(line_out, string'(" "));
            write(line_out, to_integer(y_out));
            writeline(output_file, line_out);
        end loop;
        
        -- ????? ?????????
        report "Simulation finished. Check output.txt";
        wait;
    end process;
    
end Behavioral;
